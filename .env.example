# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=idp_admin
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=idp_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_V1_STR=/api/v1
PROJECT_NAME="Arabic Enterprise Finance IDP Platform"
# Generate with: openssl rand -hex 32
SECRET_KEY=change_this_in_production_jwt_secret_32_hex_chars

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── OCR ───────────────────────────────────────────────────────────────────────
PADDLEOCR_LANG=en,ar
PADDLEOCR_USE_GPU=false

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3:8b

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760

# ── AI Training (AraBERT fine-tuning) ─────────────────────────────────────────
FINETUNED_MODEL_PATH=training/models/arabert_ner_uae

# ── ERP Connectors (fill in when testing ERP sync) ────────────────────────────
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=
ERPNEXT_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
DOLIBARR_URL=
DOLIBARR_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_grafana_password

# ── Load Testing ──────────────────────────────────────────────────────────────
LOAD_TEST_EMAIL=reviewer@idp.local
LOAD_TEST_PASSWORD=TestPass123!
LOAD_TEST_HOST=http://localhost:8000
